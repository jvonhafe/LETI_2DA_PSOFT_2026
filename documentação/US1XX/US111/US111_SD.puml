@startuml
autonumber
skinparam packageStyle rectangle

actor "ATCC" as User
participant "RouteController" as Ctrl
participant "RouteService" as Service
participant "RouteRepository" as RouteRepo
participant "RouteHistoryRepository" as HistoryRepo
database "Base de Dados" as DB

User -> Ctrl : GET /routes/{id}/history
activate Ctrl

Ctrl -> Service : getRouteHistory(id)
activate Service

Service -> RouteRepo : findById(id)
activate RouteRepo
RouteRepo -> DB : SELECT Route por ID
activate DB
DB --> RouteRepo : route
deactivate DB
RouteRepo --> Service : route
deactivate RouteRepo

Service -> HistoryRepo : findByRouteId(id)
activate HistoryRepo
HistoryRepo -> DB : SELECT histórico da rota
activate DB
DB --> HistoryRepo : historyList
deactivate DB
HistoryRepo --> Service : historyList
deactivate HistoryRepo

Service --> Ctrl : historyList
deactivate Service

Ctrl --> User : 200 OK (RouteHistory List)
deactivate Ctrl
@enduml