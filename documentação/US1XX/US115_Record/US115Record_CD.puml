@startuml
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

package "US115 - Criar Registo de Manutenção" {

    class MaintenanceRecordController <<RestController>> {
      + createRecord(record: MaintenanceRecord): MaintenanceRecord
    }

    class MaintenanceService <<Service>> {
      + createRecord(record: MaintenanceRecord): MaintenanceRecord
    }

    interface MaintenanceRecordRepository <<Repository>> {
      + save(record: MaintenanceRecord): MaintenanceRecord
    }

    interface AircraftRepository <<Repository>> {
      + findById(id: String): Optional<Aircraft>
      + save(aircraft: Aircraft): Aircraft
    }

    interface MaintenanceTemplateRepository <<Repository>> {
      + findById(id: String): Optional<MaintenanceTemplate>
    }

    class MaintenanceRecord <<Entity>> {
      - aircraftRegistration: String
      - templateId: String
      - checklist: List<String>
    }

    class MaintenanceTemplate <<Entity>> {
      - checklist: List<String>
    }

    class Aircraft <<Entity>> {
      - status: String
    }

    MaintenanceRecordController "1" --> "1" MaintenanceService : uses >
    MaintenanceService "1" --> "1" MaintenanceRecordRepository : uses >
    MaintenanceService "1" --> "1" AircraftRepository : uses >
    MaintenanceService "1" --> "1" MaintenanceTemplateRepository : uses >

    MaintenanceRecordController ..> MaintenanceRecord : handles >
    MaintenanceRecordRepository ..> MaintenanceRecord : stores >
    AircraftRepository ..> Aircraft : updates >
    MaintenanceTemplateRepository ..> MaintenanceTemplate : reads >
}
@enduml