@startuml
autonumber
actor "User" as User
participant "MaintenanceController" as Ctrl
participant "QueryService" as Service
participant "Repository" as Repo

User -> Ctrl : GET /api/maintenance/ongoing
activate Ctrl
Ctrl -> Service : getOngoingActivities(pageable)
activate Service
Service -> Repo : findByStatus("IN_PROGRESS", pageable)
activate Repo
Repo --> Service : Page<MaintenanceRecord>
deactivate Repo
Service --> Ctrl : Page<MaintenanceRecord>
deactivate Service
Ctrl --> User : 200 OK
deactivate Ctrl
@enduml