@startuml
autonumber
actor "User" as User
participant "MaintenanceController" as Ctrl
participant "QueryService" as Service
participant "Repository" as Repo

User -> Ctrl : GET /api/maintenance/average-turnaround
activate Ctrl
Ctrl -> Service : getAverageTurnaroundTime()
activate Service
Service -> Repo : getAverageTurnaroundTimePerModel()
activate Repo
Repo --> Service : List<Map<String, Object>>
deactivate Repo
Service --> Ctrl : List<Map<String, Object>>
deactivate Service
Ctrl --> User : 200 OK
deactivate Ctrl
@enduml