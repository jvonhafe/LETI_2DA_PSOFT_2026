{
  "info": {
    "name": "LETI_2DA_PSOFT_2026 - API (Completa)",
    "description": "Coleção automatizada para defesa de PSOFT. O token JWT é extraído automaticamente no Login e herdado por todos os pedidos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login Automático",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Requisito 3.6.2 - Autenticação JWT com Sucesso\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.test(\"Token JWT extraído e guardado\", function () {",
                  "        pm.expect(jsonData).to.have.property('token');",
                  "        pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
                  "        console.log(\"Token guardado com sucesso!\");",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "*/*" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"backoffice\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Airports",
      "item": [
        {
          "name": "US106 - Registar Aeroporto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"US106 - Aeroporto criado (201 Created)\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"iataCode\": \"LIS\",\n    \"name\": \"Humberto Delgado\",\n    \"city\": \"Lisboa\",\n    \"country\": \"Portugal\",\n    \"timezone\": \"GMT\",\n    \"status\": \"OPERATIONAL\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/airports",
              "host": ["{{base_url}}"],
              "path": ["airports"]
            }
          }
        },
        {
          "name": "US107 - Listar Aeroportos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"US107 - Lista de aeroportos retornada (200 OK)\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/airports",
              "host": ["{{base_url}}"],
              "path": ["airports"]
            }
          }
        },
        {
          "name": "US109 - Atualizar Estado (PATCH)",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/airports/LIS/status?status=CLOSED",
              "host": ["{{base_url}}"],
              "path": ["airports", "LIS", "status"],
              "query": [
                { "key": "status", "value": "CLOSED" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Aircrafts",
      "item": [
        {
          "name": "US101 - Registar Modelo",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"modelId\": \"A320\",\n  \"modelName\": \"Airbus A320\",\n  \"manufacturer\": \"Airbus\",\n  \"maxCapacity\": 180,\n  \"fuelCapacity\": 24000,\n  \"maxRange\": 6000,\n  \"cruisingSpeed\": 850\n}"
            },
            "url": {
              "raw": "{{base_url}}/aircraft-models",
              "host": ["{{base_url}}"],
              "path": ["aircraft-models"]
            }
          }
        }
      ]
    }
  ]
}